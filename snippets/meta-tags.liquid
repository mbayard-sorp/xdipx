{% comment %}
  Meta tags for SEO and social sharing
{% endcomment %}

<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ canonical_url }}">
<meta property="og:title" content="{{ page_title | escape | strip_html }}">
<meta property="og:type" content="website">
<meta property="og:description" content="{{ page_description | escape | strip_html }}">

{%- if request.page_type == 'product' -%}
  <meta property="og:image" content="{{ product.featured_media | image_url: width: 1200 }}">
  <meta property="og:image:secure_url" content="{{ product.featured_media | image_url: width: 1200 }}">
  <meta property="og:image:alt" content="{{ product.featured_media.alt | escape }}">
  <meta property="product:price:amount" content="{{ product.price | money_without_currency }}">
  <meta property="product:price:currency" content="{{ cart.currency.iso_code }}">
  <meta property="product:availability" content="{% if product.available %}in stock{% else %}out of stock{% endif %}">
{%- elsif request.page_type == 'article' -%}
  <meta property="og:image" content="{{ article.image | image_url: width: 1200 }}">
  <meta property="og:image:secure_url" content="{{ article.image | image_url: width: 1200 }}">
  <meta property="article:published_time" content="{{ article.published_at | date: '%Y-%m-%dT%H:%M:%SZ' }}">
  <meta property="article:modified_time" content="{{ article.updated_at | date: '%Y-%m-%dT%H:%M:%SZ' }}">
{%- else -%}
  {%- if settings.logo != blank -%}
    <meta property="og:image" content="{{ settings.logo | image_url: width: 1200 }}">
    <meta property="og:image:secure_url" content="{{ settings.logo | image_url: width: 1200 }}">
  {%- endif -%}
{%- endif -%}

{%- if page_title contains shop.name -%}
  <meta property="og:title" content="{{ page_title | escape }}">
{%- endif -%}

{%- if settings.social_twitter_link != blank -%}
  <meta name="twitter:site" content="@{{ settings.social_twitter_link | split: 'twitter.com/' | last }}">
{%- endif -%}

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ page_title | escape | strip_html }}">
<meta name="twitter:description" content="{{ page_description | escape | strip_html }}">