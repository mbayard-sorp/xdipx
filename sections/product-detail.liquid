{{ 'flash-deal-v2.css' | asset_url | stylesheet_tag }}

<section class="product-detail">
  <div class="product-detail__container">
    <!-- Gallery -->
    <div class="product-detail__gallery">
      <div class="product-detail__main-image">
        {%- if product.featured_media -%}
          {{ product.featured_media | image_url: width: 1024 | image_tag: loading: 'eager', class: 'product-detail__image' }}
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'product-detail__placeholder' }}
        {%- endif -%}
        
        {%- if product.price < product.compare_at_price -%}
          <div class="product-detail__sale-badge">
            <span>{{ product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price | round }}% OFF</span>
          </div>
        {%- endif -%}
      </div>
      
      {%- if product.media.size > 1 -%}
        <div class="product-detail__thumbnails">
          {%- for media in product.media -%}
            <button class="product-detail__thumbnail" data-media-id="{{ media.id }}">
              {{ media | image_url: width: 150 | image_tag: loading: 'lazy' }}
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- Info -->
    <div class="product-detail__info">
      <div class="product-detail__vendor">{{ product.vendor }}</div>
      
      <h1 class="product-detail__title">{{ product.title }}</h1>
      
      <div class="product-detail__rating">
        <div class="product-detail__stars">★★★★★</div>
        <span class="product-detail__review-count">(127 reviews)</span>
      </div>
      
      <div class="product-detail__price-wrap">
        <span class="product-detail__price">{{ product.price | money }}</span>
        {%- if product.compare_at_price > product.price -%}
          <span class="product-detail__price-compare">{{ product.compare_at_price | money }}</span>
        {%- endif -%}
      </div>
      
      <div class="product-detail__description">
        {{ product.content }}
      </div>

      {%- if product.variants.size > 1 -%}
        <div class="product-detail__variants">
          {%- for option in product.options -%}
            <div class="product-detail__option">
              <label class="product-detail__option-label">{{ option.name }}</label>
              <div class="product-detail__option-values">
                {%- for value in option.values -%}
                  <button class="product-detail__option-btn {% if option.selected_value == value %}active{% endif %}" data-option-name="{{ option.name }}" data-value="{{ value }}">
                    {{ value }}
                  </button>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="product-detail__quantity">
        <label class="product-detail__quantity-label">Quantity</label>
        <div class="product-detail__quantity-selector">
          <button class="product-detail__qty-btn" data-qty-minus>−</button>
          <input type="number" class="product-detail__qty-input" value="1" min="1" data-qty-input>
          <button class="product-detail__qty-btn" data-qty-plus>+</button>
        </div>
      </div>

      <form class="product-detail__form" method="post" action="/cart/add">
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" data-product-variant-id>
        <button type="submit" name="add" class="product-detail__add-btn">
          <span>Add to Cart</span>
          <svg viewBox="0 0 24 24" fill="none"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM3 6h18M16 10a4 4 0 01-8 0" stroke="currentColor" stroke-width="2"/></svg>
        </button>
      </form>

      <div class="product-detail__trust">
        <div class="product-detail__trust-item">
          <svg viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="2"/></svg>
          <span>Discreet Shipping</span>
        </div>
        <div class="product-detail__trust-item">
          <svg viewBox="0 0 24 24" fill="none"><path d="M22 11.08V12a10 10 0 11-5.93-9.14" stroke="currentColor" stroke-width="2"/><path d="M22 4L12 14.01l-3-3" stroke="currentColor" stroke-width="2"/></svg>
          <span>Body-Safe</span>
        </div>
        <div class="product-detail__trust-item">
          <svg viewBox="0 0 24 24" fill="none"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6" stroke="currentColor" stroke-width="2"/></svg>
          <span>30-Day Returns</span>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Quantity selector
  document.querySelectorAll('.product-detail__quantity-selector').forEach(function(sel) {
    var input = sel.querySelector('[data-qty-input]');
    sel.querySelector('[data-qty-minus]').addEventListener('click', function() {
      if (input.value > 1) input.value = parseInt(input.value) - 1;
    });
    sel.querySelector('[data-qty-plus]').addEventListener('click', function() {
      input.value = parseInt(input.value) + 1;
    });
  });
});
</script>

{% schema %}
{
  "name": "Product Detail",
  "tag": "section",
  "class": "section"
}
{% endschema %}
