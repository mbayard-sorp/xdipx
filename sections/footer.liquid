<footer class="footer">
  <div class="footer__container">
    <div class="footer__grid">
      <!-- Brand Column -->
      <div class="footer__column footer__column--brand">
        {%- if settings.logo != blank -%}
          <a href="{{ routes.root_url }}" class="footer__logo">
            {{ settings.logo | image_url: width: 150 | image_tag: loading: 'lazy', alt: shop.name }}
          </a>
        {%- else -%}
          <a href="{{ routes.root_url }}" class="footer__logo-text">{{ shop.name }}</a>
        {%- endif -%}
        
        <p class="footer__tagline">{{ section.settings.tagline | default: "Premium adult wellness products at unbeatable prices. Discreet shipping, satisfaction guaranteed." }}</p>
        
        <div class="footer__social">
          {%- if settings.social_facebook_link != blank -%}
            <a href="{{ settings.social_facebook_link }}" class="social-link" aria-label="Facebook">
              {% render 'icon-facebook' %}
            </a>
          {%- endif -%}
          {%- if settings.social_instagram_link != blank -%}
            <a href="{{ settings.social_instagram_link }}" class="social-link" aria-label="Instagram">
              {% render 'icon-instagram' %}
            </a>
          {%- endif -%}
          {%- if settings.social_twitter_link != blank -%}
            <a href="{{ settings.social_twitter_link }}" class="social-link" aria-label="Twitter">
              {% render 'icon-twitter' %}
            </a>
          {%- endif -%}
        </div>
      </div>

      <!-- Shop Column -->
      <div class="footer__column">
        <h4 class="footer__heading">Shop</h4>
        <ul class="footer__links">
          {%- for link in section.settings.menu_shop.links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        </ul>
      </div>

      <!-- Support Column -->
      <div class="footer__column">
        <h4 class="footer__heading">Support</h4>
        <ul class="footer__links">
          {%- for link in section.settings.menu_support.links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
          <li><a href="{{ routes.contact_url }}">Contact Us</a></li>
        </ul>
      </div>

      <!-- Newsletter Column -->
      <div class="footer__column footer__column--newsletter">
        <h4 class="footer__heading">{{ section.settings.newsletter_heading | default: "Get Exclusive Deals" }}</h4>
        <p class="footer__newsletter-text">{{ section.settings.newsletter_text | default: "Subscribe for flash sale alerts and exclusive discounts." }}</p>
        
        {%- form 'customer', id: 'ContactFooter-newsletter' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="footer__newsletter-form">
            <input
              id="ContactFooter-email"
              type="email"
              name="contact[email]"
              value="{{ form.email }}"
              placeholder="Enter your email"
              required
            >
            <button type="submit" class="button button--newsletter">
              {% render 'icon-arrow' %}
            </button>
          </div>
          {%- if form.errors -%}
            <small class="footer__error">{{ form.errors.translated_fields['email'] }} {{ form.errors.messages['email'] }}.</small>
          {%- endif -%}
        {%- endform -%}
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="footer__bottom">
      <div class="footer__bottom-left">
        <p>&copy; {{ 'now' | date: "%Y" }} {{ shop.name | link_to: routes.root_url }}. All rights reserved.</p>
      </div>
      
      <div class="footer__bottom-right">
        <span class="footer__disclaimer">{{ section.settings.disclaimer | default: "Adults 18+ only. You confirm you are of legal age." }}</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-secondary);
    color: white;
    padding: 4rem 2rem 2rem;
  }

  .footer__container {
    max-width: var(--page-width);
    margin: 0 auto;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 2fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  @media (max-width: 1024px) {
    .footer__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .footer__grid {
      grid-template-columns: 1fr;
    }
  }

  /* Brand Column */
  .footer__logo {
    display: inline-block;
    margin-bottom: 1rem;
  }

  .footer__logo-text {
    font-size: 2rem;
    font-weight: 700;
    color: white;
    text-decoration: none;
  }

  .footer__tagline {
    font-size: 1.4rem;
    opacity: 0.8;
    line-height: 1.5;
    margin-bottom: 1.5rem;
    max-width: 280px;
  }

  .footer__social {
    display: flex;
    gap: 1rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    color: white;
    transition: background 0.2s ease;
  }

  .social-link:hover {
    background: var(--color-primary);
  }

  .social-link svg {
    width: 20px;
    height: 20px;
    fill: currentColor;
  }

  /* Links */
  .footer__heading {
    font-size: 1.4rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    color: white;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer__links li {
    margin-bottom: 0.75rem;
  }

  .footer__links a {
    color: white;
    opacity: 0.7;
    text-decoration: none;
    font-size: 1.4rem;
    transition: opacity 0.2s ease;
  }

  .footer__links a:hover {
    opacity: 1;
    color: var(--color-accent);
  }

  /* Newsletter */
  .footer__newsletter-text {
    font-size: 1.4rem;
    opacity: 0.8;
    margin-bottom: 1rem;
  }

  .footer__newsletter-form {
    display: flex;
    gap: 0.5rem;
  }

  .footer__newsletter-form input {
    flex: 1;
    padding: 1rem;
    border: none;
    border-radius: 4px;
    font-size: 1.4rem;
    background: rgba(255, 255, 255, 0.1);
    color: white;
  }

  .footer__newsletter-form input::placeholder {
    color: rgba(255, 255, 255, 0.5);
  }

  .footer__newsletter-form input:focus {
    outline: 2px solid var(--color-primary);
  }

  .button--newsletter {
    padding: 1rem 1.5rem;
  }

  .footer__error {
    display: block;
    margin-top: 0.5rem;
    font-size: 1.2rem;
    color: #FF6B6B;
  }

  /* Bottom Bar */
  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer__bottom p {
    font-size: 1.2rem;
    opacity: 0.6;
    margin: 0;
  }

  .footer__disclaimer {
    font-size: 1rem;
    opacity: 0.4;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline"
    },
    {
      "type": "link_list",
      "id": "menu_shop",
      "label": "Shop Menu",
      "default": "footer"
    },
    {
      "type": "link_list",
      "id": "menu_support",
      "label": "Support Menu"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter Heading"
    },
    {
      "type": "text",
      "id": "newsletter_text",
      "label": "Newsletter Text"
    },
    {
      "type": "text",
      "id": "disclaimer",
      "label": "Age Disclaimer"
    }
  ]
}
{% endschema %}