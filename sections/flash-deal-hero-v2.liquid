<section class="hero-flash" data-section-id="{{ section.id }}">
  <div class="hero-flash__bg">
    <div class="hero-flash__gradient"></div>
    <div class="hero-flash__pattern"></div>
  </div>
  
  <div class="hero-flash__container">
    <!-- Countdown Badge -->
    <div class="hero-flash__badge">
      <span class="hero-flash__badge-icon">⚡</span>
      <span class="hero-flash__badge-text">Flash Deal Ends Soon</span>
    </div>

    <div class="hero-flash__content">
      <!-- Product Image -->
      <div class="hero-flash__image-wrapper">
        <div class="hero-flash__image-frame">
          {%- if section.settings.product != blank -%}
            {% assign product = section.settings.product %}
            {% if product.featured_media %}
              {{ product.featured_media | image_url: width: 800 | image_tag: loading: 'eager', class: 'hero-flash__image' }}
            {% else %}
              {{ 'product-1' | placeholder_svg_tag: 'hero-flash__placeholder' }}
            {% endif %}
            
            <!-- Sale Badge -->
            {% if product.price < product.compare_at_price %}
              {% assign savings = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
              <div class="hero-flash__sale-badge">
                <span class="hero-flash__sale-percent">{{ savings | round }}%</span>
                <span class="hero-flash__sale-label">OFF</span>
              </div>
            {% endif %}
          {% else %}
            {{ 'product-1' | placeholder_svg_tag: 'hero-flash__placeholder' }}
          {% endif %}
        </div>
        <div class="hero-flash__glow"></div>
      </div>

      <!-- Product Details -->
      <div class="hero-flash__details">
        <!-- Vendor Tag -->
        <div class="hero-flash__vendor">
          {%- if section.settings.product != blank -%}
            {{ section.settings.product.vendor | escape }}
          {%- else -%}
            TheVibed
          {%- endif -%}
        </div>

        <!-- Title -->
        <h1 class="hero-flash__title">
          {%- if section.settings.product != blank -%}
            {{ section.settings.product.title | escape }}
          {%- else -%}
            inBloom Rosales Sucking Vibrator
          {%- endif -%}
        </h1>

        <!-- Description -->
        <p class="hero-flash__description">
          {%- if section.settings.product != blank -%}
            {{ section.settings.product.description | truncate: 200 }}
          {%- else -%}
            10 suction modes from gentle breeze to holy moly. Rose-shaped, fits in your palm, made of body-safe silicone. The TikTok sensation now at an exclusive price.
          {%- endif -%}
        </p>

        <!-- Price -->
        <div class="hero-flash__price-wrapper">
          <span class="hero-flash__price-current">
            {%- if section.settings.product != blank -%}
              {{ section.settings.product.price | money }}
            {%- else -%}
              $50.00
            {%- endif -%}
          </span>
          {%- if section.settings.product != blank and section.settings.product.compare_at_price > section.settings.product.price -%}
            <span class="hero-flash__price-compare">
              {{ section.settings.product.compare_at_price | money }}
            </span>
          {%- else -%}
            <span class="hero-flash__price-compare">$89.99</span>
          {%- endif -%}
        </div>

        <!-- Countdown Timer -->
        <div class="hero-flash__countdown" data-countdown="{{ section.settings.countdown_end | default: '2026-03-27T00:00:00' }}">
          <div class="hero-flash__countdown-header">
            <span class="hero-flash__countdown-label">Deal ends in</span>
          </div>
          <div class="hero-flash__countdown-timer">
            <div class="hero-flash__countdown-unit">
              <span class="hero-flash__countdown-num" data-hours>00</span>
              <span class="hero-flash__countdown-text">Hours</span>
            </div>
            <span class="hero-flash__countdown-sep">:</span>
            <div class="hero-flash__countdown-unit">
              <span class="hero-flash__countdown-num" data-minutes>00</span>
              <span class="hero-flash__countdown-text">Minutes</span>
            </div>
            <span class="hero-flash__countdown-sep">:</span>
            <div class="hero-flash__countdown-unit">
              <span class="hero-flash__countdown-num" data-seconds>00</span>
              <span class="hero-flash__countdown-text">Seconds</span>
            </div>
          </div>
        </div>

        <!-- Stock Indicator -->
        <div class="hero-flash__stock">
          <div class="hero-flash__stock-bar">
            <div class="hero-flash__stock-fill" style="width: 65%"></div>
          </div>
          <div class="hero-flash__stock-text">
            <span class="hero-flash__stock-num">1,201</span> units remaining
          </div>
        </div>

        <!-- CTA Button -->
        <a href="{{ section.settings.product.url | default: '#' }}" class="hero-flash__cta">
          <span class="hero-flash__cta-text">Add to Cart</span>
          <svg class="hero-flash__cta-arrow" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>

        <!-- Trust Signals -->
        <div class="hero-flash__trust">
          <div class="hero-flash__trust-item">
            <svg viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="2"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="2"/></svg>
            <span>Discreet Shipping</span>
          </div>
          <div class="hero-flash__trust-item">
            <svg viewBox="0 0 24 24" fill="none"><path d="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4z" stroke="currentColor" stroke-width="2"/></svg>
            <span>Free Over $50</span>
          </div>
          <div class="hero-flash__trust-item">
            <svg viewBox="0 0 24 24" fill="none"><path d="M3 12a9 9 0 109-9 9.75 9.75 0 00-6.74 2.74L3 8M3 3v5h5" stroke="currentColor" stroke-width="2"/><path d="M3 12a9 9 0 019 9" stroke="currentColor" stroke-width="2"/></svg>
            <span>30-Day Returns</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const countdown = document.querySelector('[data-countdown]');
  if (!countdown) return;
  
  const endTime = new Date(countdown.dataset.countdown).getTime();
  
  function update() {
    const now = new Date().getTime();
    const diff = endTime - now;
    
    if (diff < 0) {
      countdown.innerHTML = '<div class="hero-flash__countdown-expired">Deal has ended</div>';
      return;
    }
    
    const hours = Math.floor(diff / (1000 * 60 * 60));
    const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
    const seconds = Math.floor((diff % (1000 * 60)) / 1000);
    
    const hoursEl = countdown.querySelector('[data-hours]');
    const minutesEl = countdown.querySelector('[data-minutes]');
    const secondsEl = countdown.querySelector('[data-seconds]');
    
    if (hoursEl) hoursEl.textContent = String(hours).padStart(2, '0');
    if (minutesEl) minutesEl.textContent = String(minutes).padStart(2, '0');
    if (secondsEl) secondsEl.textContent = String(seconds).padStart(2, '0');
  }
  
  update();
  setInterval(update, 1000);
});
</script>

{% schema %}
{
  "name": "Flash Deal Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Deal Product"
    },
    {
      "type": "text",
      "id": "countdown_end",
      "label": "Countdown End Time",
      "default": "2026-03-27T00:00:00"
    }
  ],
  "presets": [{"name": "Flash Deal Hero"}]
}
{% endschema %}